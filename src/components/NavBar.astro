---
export interface Props {
    links:{title: string, url: string}[];
}
const { links } = Astro.props; 
import logo from "../assets/img/blog-placeholder-4.jpg";
---
<nav id="navbar" class="sticky shadow-md bg-white top-0 w-full px-8 py-4 flex items-center justify-between transition-colors duration-300 z-50">
  
  <!-- Left section: Logo -->
  <a href="/" class="flex-shrink-0">
    <img src={logo.src} alt="Keele Logo" width="100" height="100" />
  </a>

  <!-- Center section: Nav links -->
  <div class="flex space-x-4">
    {links.map(link => (
      <a href={link.url} class="text-black font-medium hover:underline">{link.title}</a>
    ))}
  </div>

  <!-- Right section: Button -->
</nav>
<script is:inline>
  
  const navBar = document.getElementById("navbar");
  window.addEventListener("scroll",()=>{
    if(window.scrollY > 50){
      navBar.classList.add("bg-[var(--sage)]", "shadow-md");
    }else{
      navBar.classList.remove("bg-[var(--slate)]", "shadow-md");
    }
  });
</script>